{
  "name": "byronwade-ui",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync": "node scripts/sync-registry.mjs",
    "update:registry": "node scripts/update-registry.mjs",
    "check:registry": "node scripts/check-registry.mjs",
    "check:registry:built": "node scripts/check-registry.mjs --built",
    "check:examples": "node scripts/check-examples.mjs",
    "check:rule": "node scripts/check-rule.mjs",
    "check:conventions": "node scripts/check-conventions.mjs",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "validate": "node scripts/check-registry.mjs && node scripts/check-examples.mjs && node scripts/check-rule.mjs && node scripts/check-conventions.mjs && npm run check:tests && node scripts/check-lint-manifest.mjs && node scripts/check-mcp-data.mjs && node scripts/check-llms-txt.mjs",
    "predev": "node scripts/sync-registry.mjs",
    "dev": "next dev",
    "registry:build": "shadcn build",
    "gen:examples": "node scripts/gen-examples-registry.mjs",
    "prebuild": "node scripts/gen-lint-manifest.mjs && node --import tsx scripts/gen-mcp-data.mjs && node --import tsx scripts/gen-llms-txt.mjs && node scripts/gen-all-item.mjs && shadcn build && node scripts/sync-registry.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pretest": "node scripts/sync-registry.mjs",
    "test": "vitest",
    "pretest:run": "node scripts/sync-registry.mjs",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:tests": "node scripts/check-test-coverage.mjs",
    "pretest:ci": "node scripts/sync-registry.mjs",
    "test:ci": "npm run check:tests && vitest run --coverage",
    "gen:lint-manifest": "node scripts/gen-lint-manifest.mjs",
    "check:lint-manifest": "node scripts/check-lint-manifest.mjs",
    "test:packages": "npm run test --workspaces --if-present",
    "build:lint": "npm run build --workspace @byronwade/on-system-core && npm run build --workspace @byronwade/lint",
    "lint:on-system": "npm run build:lint && node packages/lint-cli/dist/cli.js \"registry/**/*.{ts,tsx}\" --off-system-components off --error-detectors raw-color,hand-rolled,typography",
    "eval": "npm run build --workspace @byronwade/eval && node packages/eval/dist/cli.js",
    "gen:mcp-data": "node --import tsx scripts/gen-mcp-data.mjs",
    "check:mcp-data": "node scripts/check-mcp-data.mjs",
    "gen:llms": "node --import tsx scripts/gen-llms-txt.mjs",
    "check:llms": "node scripts/check-llms-txt.mjs",
    "gen:thumbs": "node --import tsx scripts/gen-thumbs.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/dom": "^1.7.6",
    "@tiptap/core": "^3.25.0",
    "@tiptap/extension-code-block-lowlight": "^3.25.0",
    "@tiptap/extension-list": "^3.25.0",
    "@tiptap/extension-subscript": "^3.25.0",
    "@tiptap/extension-superscript": "^3.25.0",
    "@tiptap/extension-table": "^3.25.0",
    "@tiptap/extension-text-style": "^3.25.0",
    "@tiptap/extension-typography": "^3.25.0",
    "@tiptap/extensions": "^3.25.0",
    "@tiptap/pm": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@tiptap/suggestion": "^3.25.0",
    "@uidotdev/usehooks": "^2.4.1",
    "@xyflow/react": "^12.11.0",
    "ai": "^6.0.196",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "color": "^5.0.3",
    "date-fns": "^4.4.0",
    "dotted-map": "^3.1.0",
    "fuse.js": "^7.4.1",
    "jotai": "^2.20.0",
    "lodash.throttle": "^4.1.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.17.0",
    "media-chrome": "^4.19.1",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-image-crop": "^11.0.10",
    "react-svg-credit-card-payment-icons": "^6.0.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.9.0",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tippy.js": "^6.3.7",
    "tokenlens": "^1.3.1",
    "tunnel-rat": "^0.1.2",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.40.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "culori": "^4.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "fast-glob": "^3.3.2",
    "jsdom": "^29.1.1",
    "picocolors": "^1.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0",
    "zod": "^3.24.1"
  }
}
