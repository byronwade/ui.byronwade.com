      "css": {
        "@layer base": {
          "body": {
            "font-feature-settings": "\"liga\" 1, \"calt\" 1",
            "-webkit-font-smoothing": "antialiased",
            "-moz-osx-font-smoothing": "grayscale",
            "text-rendering": "optimizeLegibility",
            "letter-spacing": "-0.006em",
            "line-height": "1.6"
          },
          "h1, h2, h3, h4": {
            "letter-spacing": "-0.02em",
            "line-height": "1.15"
          }
        },
        "@layer utilities": {
          ".bg-grid": {
            "background-image": "radial-gradient(circle at 1px 1px, color-mix(in oklch, var(--foreground) 12%, transparent) 1px, transparent 0)",
            "background-size": "28px 28px"
          },
          ".bg-grid-lines": {
            "background-image": "linear-gradient(to right, color-mix(in oklch, var(--border) 70%, transparent) 1px, transparent 1px), linear-gradient(to bottom, color-mix(in oklch, var(--border) 70%, transparent) 1px, transparent 1px)",
            "background-size": "56px 56px"
          },
          ".glow-brand": {
            "background": "radial-gradient(60% 60% at 50% 0%, color-mix(in oklch, var(--brand) 28%, transparent) 0%, transparent 70%)"
          },
          ".text-gradient": {
            "background": "linear-gradient(180deg, var(--foreground) 0%, color-mix(in oklch, var(--foreground) 62%, transparent) 100%)",
            "-webkit-background-clip": "text",
            "background-clip": "text",
            "color": "transparent"
          },
          ".text-gradient-brand": {
            "background": "linear-gradient(135deg, var(--foreground) 0%, var(--brand) 120%)",
            "-webkit-background-clip": "text",
            "background-clip": "text",
            "color": "transparent"
          },
          ".mask-fade-x": {
            "mask-image": "linear-gradient(to right, transparent, black 8%, black 92%, transparent)"
          },
          ".full-bleed": {
            "width": "100vw",
            "margin-left": "calc(50% - 50vw)",
            "margin-right": "calc(50% - 50vw)"
          },
          ".edge": {
            "box-shadow": "inset 0 0 0 1px var(--edge)"
          }
        },
        ".scrollbar-thin": {
          "scrollbar-width": "thin",
          "scrollbar-color": "var(--border) transparent"
        }
      }
    },
